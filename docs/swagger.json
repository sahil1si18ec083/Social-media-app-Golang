        ],
        "responses": {
          "200": {
            "description": "Comment created successfully",
            "schema": {
              "$ref": "#/definitions/store.Post"
            }
          },
          "400": {
            "description": "Bad request",
            "schema": {
              "type": "object",
              "additionalProperties": {
