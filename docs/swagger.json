    "/posts/{postID}/comments": {
      "post": {
        "tags": [
          "comments"
        ],
        "summary": "Create comment on post",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "type": "integer",
            "name": "postID",
            "in": "path",
