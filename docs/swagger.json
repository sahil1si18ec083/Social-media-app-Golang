      },
      "delete": {
        "tags": [
          "posts"
        ],
        "summary": "Delete post",
        "produces": [
          "application/json"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "type": "integer",
            "name": "postID",
